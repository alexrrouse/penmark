#!/bin/bash
# penmark - Open a file or directory in Penmark
# Usage: penmark [path]
#   path  File or directory to open (default: current directory)

ARG="${1:-.}"

# Resolve to absolute path
if [ -f "$ARG" ]; then
    # It's a file — resolve its absolute path
    FILE_DIR="$(cd "$(dirname "$ARG")" 2>/dev/null && pwd)" || {
        echo "penmark: cannot resolve path for '$1'" >&2
        exit 1
    }
    PATH_ARG="$FILE_DIR/$(basename "$ARG")"
elif [ -d "$ARG" ]; then
    # It's a directory — resolve its absolute path
    PATH_ARG="$(cd "$ARG" 2>/dev/null && pwd)" || {
        echo "penmark: cannot access '$1': No such directory" >&2
        exit 1
    }
else
    echo "penmark: '$ARG' does not exist" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_PATHS=(
    "/Applications/Penmark.app"
    "$HOME/Applications/Penmark.app"
    "$HOME/Desktop/Penmark.app"
    "$SCRIPT_DIR/build/Build/Products/Release/Penmark.app"
)

APP_PATH=""
for path in "${APP_PATHS[@]}"; do
    if [ -d "$path" ]; then
        APP_PATH="$path"
        break
    fi
done

if [ -z "$APP_PATH" ]; then
    APP_PATH=$(mdfind "kMDItemCFBundleIdentifier == 'com.penmark.app'" 2>/dev/null | head -1)
fi

if [ -z "$APP_PATH" ]; then
    echo "penmark: Penmark.app not found. Build the project in Xcode and copy to /Applications." >&2
    exit 1
fi

open -n "$APP_PATH" --args "$PATH_ARG"
